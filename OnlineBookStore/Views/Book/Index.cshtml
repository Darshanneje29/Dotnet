@model List<OnlineBookStore.Models.Book>

<h2>Book List</h2>
<a href="/Book/Create">Add Book</a>

@if (Model.Count == 0)
{
    <p>No books available</p>
}
else
{
<table border="1">
<tr>
<th>Title</th><th>Author</th><th>Price</th><th>Quantity</th><th>Action</th>
</tr>
@foreach (var book in Model)
{
<tr>
<td>@book.Title</td>
<td>@book.Author</td>
<td>@book.Price</td>
<td>@book.Quantity</td>
<td>
<a href="/Book/Edit/@book.Id">Edit</a> |
<a href="/Book/Delete/@book.Id">Delete</a>
</td>
</tr>
}
</table>
}